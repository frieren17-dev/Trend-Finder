# ── Trend Finder environment ────────────────────────────────────────────────
# Copy this file to `.env` and fill in your Gemini key. NEVER commit `.env`.
# Both servers (Flask :5001 and Node serve.mjs :3002) read this file.

# Google Gemini API key (used for TEXT analysis only — no image generation).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use (text). Default gemini-2.5-flash.
# IMPORTANT: free-tier quota is PER-MODEL-PER-DAY. If you hit HTTP 429
# (RESOURCE_EXHAUSTED), that model's daily quota is used up — switch to another
# (each has its own bucket), e.g. gemini-flash-lite-latest or gemini-2.5-flash-lite,
# wait for the daily reset, or enable billing on the key.
GEMINI_MODEL=gemini-2.5-flash

# Ports / wiring (defaults shown — usually no need to change).
FLASK_PORT=5001
NODE_PORT=3002
FLASK_BASE=http://localhost:5001
